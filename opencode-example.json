{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "./Overpowers/.opencode/plugin/Overpowers.js",
        "envsitter-guard"
    ],
    "mcp": {
        "serena": {
            "type": "local",
            "enabled": true,
            "command": [
                "{env:UVX_PATH}",
                "--from",
                "{env:SERENA_PATH}",
                "serena",
                "start-mcp-server",
                "--context",
                "ide-assistant"
            ]
        },
        "vibe_check": {
            "type": "local",
            "enabled": true,
            "command": [
                "node",
                "{env:VIBE_CHECK_PATH}"
            ],
            "environment": {
                "GEMINI_API_KEY": "{env:GEMINI_API_KEY}",
                "MCP_TRANSPORT": "stdio"
            }
        },
        "desktop_commander": {
            "type": "local",
            "enabled": true,
            "command": [
                "node",
                "{env:DESKTOP_COMMANDER_PATH}"
            ]
        },
        "hyperbrowser": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "--yes",
                "hyperbrowser-mcp"
            ],
            "environment": {
                "HYPERBROWSER_API_KEY": "{env:HYPERBROWSER_API_KEY}"
            }
        },
        "genkit-mcp-server": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "genkit-cli@^1.28.0",
                "mcp",
                "--explicitProjectRoot",
                "--no-update-notification",
                "--non-interactive"
            ]
        },
        "memcord": {
            "type": "local",
            "enabled": true,
            "command": [
                "{env:UVX_PATH}",
                "memcord",
                "server"
            ],
            "environment": {
                "MEMCORD_ENABLE_ADVANCED": "true"
            }
        },
        "in_memoria": {
            "type": "local",
            "enabled": true,
            "command": [
                "node",
                "{env:IN_MEMORIA_PATH}",
                "server"
            ]
        },
        "playwright_browser": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@playwright/mcp@latest"
            ]
        },
        "context7": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@upstash/context7-mcp"
            ],
            "environment": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            }
        },
        "semgrep": {
            "type": "local",
            "enabled": true,
            "command": [
                "semgrep",
                "mcp"
            ]
        },
        "notebooklm": {
            "type": "local",
            "enabled": true,
            "command": [
                "{env:UVX_PATH}",
                "--from",
                "{env:NOTEBOOKLM_PATH}",
                "notebooklm-mcp",
                "run"
            ]
        },
        "grep_app": {
            "type": "remote",
            "enabled": true,
            "url": "https://mcp.grep.app",
            "oauth": false
        },
        "web_search": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-brave-search"
            ],
            "environment": {
                "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
            }
        }
    }
}
