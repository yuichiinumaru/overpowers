#!/bin/bash

cat <<EOF > task_plan.md
# Task Plan: [Title]

## Goal
[High-level goal]

## Phases
- [ ] Phase 1: Planning
- [ ] Phase 2: Implementation
- [ ] Phase 3: Delivery

## Status
**Currently in Phase 1**
EOF

cat <<EOF > notes.md
# Notes

## Findings
- 

## Decisions
- 
EOF

cat <<EOF > findings.md
# Final Findings

## Summary
- 
EOF

echo "Planning files initialized: task_plan.md, notes.md, findings.md"
