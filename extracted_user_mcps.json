{
    "mcp": {
        "hyperbrowser": {
            "command": "npx",
            "args": [
                "--yes",
                "hyperbrowser-mcp"
            ],
            "env": {
                "HYPERBROWSER_API_KEY": "your_hyperbrowser_api_key_here"
            }
        },
        "genkit-mcp-server": {
            "command": "npx",
            "args": [
                "-y",
                "genkit-cli@^1.28.0",
                "mcp",
                "--explicitProjectRoot",
                "--no-update-notification",
                "--non-interactive"
            ],
            "env": {}
        },
        "memcord": {
            "command": "/home/sephiroth/anaconda3/bin/uvx",
            "args": [
                "memcord",
                "server"
            ],
            "env": {
                "MEMCORD_ENABLE_ADVANCED": "true"
            }
        },
        "vibe_check": {
            "command": "node",
            "args": [
                "/home/sephiroth/Work/overpowers/packages/vibe-check-mcp-server/build/index.js"
            ],
            "env": {
                "GEMINI_API_KEY": "your_gemini_api_key_here",
                "MCP_TRANSPORT": "stdio"
            }
        },
        "in_memoria": {
            "command": "node",
            "args": [
                "/home/sephiroth/Work/overpowers/packages/In-Memoria/dist/index.js",
                "server"
            ],
            "env": {}
        },
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp"
            ],
            "env": {
                "CONTEXT7_API_KEY": "your_context7_api_key_here"
            }
        },
        "playwright_browser": {
            "command": "npx",
            "args": [
                "-y",
                "@playwright/mcp@latest"
            ],
            "env": {}
        },
        "serena": {
            "command": "/home/sephiroth/anaconda3/bin/uvx",
            "args": [
                "--from",
                "/home/sephiroth/Work/overpowers/packages/serena",
                "serena",
                "start-mcp-server",
                "--context",
                "ide-assistant"
            ],
            "env": {}
        },
        "notebooklm": {
            "command": "/home/sephiroth/anaconda3/bin/uvx",
            "args": [
                "--from",
                "/home/sephiroth/Work/overpowers/packages/notebooklm-mcp-cli",
                "notebooklm-mcp",
                "run"
            ],
            "env": {}
        },
        "desktop_commander": {
            "command": "node",
            "args": [
                "/home/sephiroth/Work/overpowers/packages/DesktopCommanderMCP/dist/index.js"
            ],
            "env": {}
        },
        "semgrep": {
            "command": "semgrep",
            "args": [
                "mcp"
            ],
            "env": {}
        }
    }
}