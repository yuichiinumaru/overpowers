# =============================================================================
# Overpowers MCP Configuration - Environment Variables
# =============================================================================
# Copy this file to .env and replace the placeholder values with your real
# API keys and local paths.
#
# Paths marked with ./packages/ reference local clones inside this repo.
# Run `scripts/setup/build-packages.sh` to build them before first use.
# =============================================================================

# --- Paths ---
# UVX: absolute path to uvx binary (needed by platforms where uvx isn't in PATH)
UVX_PATH=/home/sephiroth/anaconda3/bin/uvx

# --- API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
HYPERBROWSER_API_KEY=your_hyperbrowser_api_key_here
CONTEXT7_API_KEY=your_context7_api_key_here
BRAVE_API_KEY=your_brave_api_key_here

# --- Overpowers Root (auto-detected by install scripts) ---
OVERPOWERS_ROOT=./overpowers

# --- MCP Server Paths (local packages) ---

# In-Memoria: vector memory MCP (Node.js, built from packages/In-Memoria)
IN_MEMORIA_PATH=./packages/In-Memoria/dist/index.js

# Vibe Check: metacognitive questioning MCP (Node.js, built from packages/vibe-check-mcp-server)
VIBE_CHECK_PATH=./packages/vibe-check-mcp-server/build/index.js

# Semgrep: uses native `semgrep mcp` command (install via pip install semgrep)
# No path variable needed

# Serena: semantic code retrieval MCP (Python, from packages/serena)
SERENA_PATH=./packages/serena

# NotebookLM: Google NotebookLM MCP (Python, from packages/notebooklm-mcp-cli)
NOTEBOOKLM_PATH=./packages/notebooklm-mcp-cli

# Memcord: persistent memory slots MCP (Python, local install)
# Run: cd ~/.config/opencode/mcp/memcord && uv venv && uv pip install -e .
MEMCORD_PYTHON_PATH=$HOME/.config/opencode/mcp/memcord/.venv/bin/python
MEMCORD_SRC_PATH=$HOME/.config/opencode/mcp/memcord/src

# Desktop Commander: system control MCP (Node.js, built from packages/DesktopCommanderMCP)
DESKTOP_COMMANDER_PATH=./packages/DesktopCommanderMCP/dist/index.js

# --- Optional ---
MCP_TRANSPORT=
MEMCORD_ENABLE_ADVANCED=
